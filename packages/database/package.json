{
  "name": "@omr-prod/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:edge:generate": "drizzle-kit generate --config=drizzle.edge.config.ts",
    "db:cloud:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:generate": "npm run db:cloud:generate",
    "db:push": "drizzle-kit push --config=drizzle.edge.config.ts",
    "db:edge:push": "drizzle-kit push --config=drizzle.edge.config.ts",
    "db:cloud:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:edge:migrate": "drizzle-kit migrate --config=drizzle.edge.config.ts",
    "db:cloud:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "seed:essential": "tsx seed-essential.ts",
    "seed:regions": "tsx seed-regions.ts",
    "seed:demo": "tsx seed-demo.ts",
    "db:cloud:seed": "tsx seed-demo.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "tsx": "^4.21.0",
    "@types/bcrypt": "^6.0.0"
  }
}