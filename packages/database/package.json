  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate --config=drizzle.edge.config.ts",
    "db:push": "drizzle-kit push:sqlite --config=drizzle.edge.config.ts",
    "db:edge:push": "drizzle-kit push:sqlite --config=drizzle.edge.config.ts",
