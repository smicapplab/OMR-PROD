{
  "$schema": "https://json.schemastore.org/tsconfig-base",
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@omr-prod/database": ["../../packages/database/src"],
      "@omr-prod/database/*": ["../../packages/database/src/*"],
      "@omr-prod/contracts": ["../../packages/contracts/src"],
      "@omr-prod/contracts/*": ["../../packages/contracts/src/*"]
    }
  }
}
