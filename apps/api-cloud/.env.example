# Database Configuration
DATABASE_URL="postgres://postgres:postgres@localhost:5432/omr_prod"

# JWT Configuration
JWT_SECRET="your-super-secret-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"
JWT_TTL="1h"
JWT_REFRESH_TTL="7d"

# Machine Enrollment
ENROLLMENT_SECRET="change-this-for-prod"

# Server
# Port the API listens on (default: 4000)
PORT=4000

# Comma-separated list of allowed CORS origins
# For Linode: set to the actual web-cloud URL, e.g. http://<linode-ip>:3000
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
